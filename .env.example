# Runtime environment variables
# These are the values used by the app inside the running container.

# Required runtime profile: dev | staging | prod
MCP_ENVIRONMENT=dev

# Optional runtime metadata surfaced by server_info
MCP_SERVER_VERSION=0.1.0
MCP_BUILD_ID=local-dev
MCP_BUILD_COMMIT=abc1234
MCP_BUILD_TIME=2026-03-15T10:30:00Z

# Secret-backed runtime value.
# Required for staging/prod. For Cloud Run, prefer Secret Manager instead of
# putting the real value in a committed file.
YOUTUBE_API_KEY=
MCP_AUTH_TOKEN=

# Hosted MCP security controls.
# Leave MCP_AUTH_REQUIRED blank to use environment defaults.
MCP_AUTH_REQUIRED=
MCP_ALLOWED_ORIGINS=http://localhost:3000
MCP_ALLOW_ORIGINLESS_CLIENTS=true

# Local deployment workflow variables
# These are used by scripts/deploy_cloud_run.sh on your machine and are not all
# injected into the running container.

PROJECT_ID=my-gcp-project
REGION=us-central1
SERVICE_NAME=youtube-mcp-server
IMAGE_REFERENCE=us-docker.pkg.dev/my-gcp-project/apps/youtube-mcp-server:build-20260315-01
SERVICE_ACCOUNT_EMAIL=youtube-mcp-server@my-gcp-project.iam.gserviceaccount.com
MCP_SERVER_IMPLEMENTATION=uvicorn
MCP_ASGI_APP=mcp_server.cloud_run_entrypoint:app
MIN_INSTANCES=0
MAX_INSTANCES=2
CONCURRENCY=20
TIMEOUT_SECONDS=180

# Comma-separated Secret Manager secret names to wire into Cloud Run.
SECRET_REFERENCES=YOUTUBE_API_KEY

# Optional override when gcloud is not on PATH locally.
GCLOUD_BIN=/opt/homebrew/bin/gcloud
