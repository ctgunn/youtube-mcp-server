# Runtime profile (required): dev | staging | prod
MCP_ENVIRONMENT=dev

# Optional metadata
MCP_SERVER_VERSION=0.1.0
MCP_BUILD_ID=local
MCP_BUILD_COMMIT=unknown
MCP_BUILD_TIME=unknown

# Required in staging/prod
YOUTUBE_API_KEY=

# Hosted deployment inputs
PROJECT_ID=
REGION=us-central1
SERVICE_NAME=youtube-mcp-server
IMAGE_REFERENCE=
SERVICE_ACCOUNT_EMAIL=
MIN_INSTANCES=0
MAX_INSTANCES=2
CONCURRENCY=20
TIMEOUT_SECONDS=180
SECRET_REFERENCES=YOUTUBE_API_KEY
